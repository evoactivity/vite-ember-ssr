{
  "name": "test-server",
  "version": "1.0.0",
  "description": "SSR server for the test Ember application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "node index.js --dev",
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.3",
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "fastify": "^5.8.4",
    "vite-ember-ssr": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
