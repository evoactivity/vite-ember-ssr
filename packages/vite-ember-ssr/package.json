{
  "name": "vite-ember-ssr",
  "version": "0.0.1",
  "description": "Vite plugin and SSR runtime for Ember.js applications",
  "type": "module",
  "exports": {
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "happy-dom": "^17.4.4"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
